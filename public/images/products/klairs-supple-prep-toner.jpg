      <script src="//www.klairs.com/cdn/shop/t/13/assets/quick-view.js?v=93783555645323306721756972619" defer="defer"></script>
    
<script src="//www.klairs.com/cdn/shop/t/13/assets/compare.js?v=152224050373430531111756972619" defer="defer"></script><script>
document.addEventListener('DOMContentLoaded', function() {
  try {
    let signupMethod = '';
    
    // 경로 1: 계정 생성 (세션 스토리지 확인)
    const marketingOptIn = sessionStorage.getItem('klairs_marketing_opt_in');
    if (marketingOptIn === 'true') {
      const referrerIsRegisterPage = document.referrer.includes('/account/register');
      if(referrerIsRegisterPage) {
         signupMethod = 'Account Creation';
      }
    }
    if (marketingOptIn !== null) {
        sessionStorage.removeItem('klairs_marketing_opt_in');
    }

    // 경로 2 & 3: Footer/팝업 (URL 확인 + 세션 스토리지로 중복 방지)
    const urlParams = new URLSearchParams(window.location.search);
    const hasPosted = urlParams.get('customer_posted') === 'true';
    if (hasPosted && !sessionStorage.getItem('klairs_form_signup_tracked')) {
      if (window.location.hash.includes('ContactSubscribe-Popup')) {
        signupMethod = 'Popup Form';
      } else if (window.location.hash.includes('ContactSubscribe-newsletter')) {
        signupMethod = 'Footer Form';
      }
      // 폼 가입이 추적되었다고 세션에 기록
      if (signupMethod.includes('Form')) {
          sessionStorage.setItem('klairs_form_signup_tracked', 'true');
      }
    }

    if (signupMethod) {
      console.log('Klairs Signup Detected. Method:', signupMethod);
      
      let metaFired = false;
      let gaFired = false;
      let attempts = 0;
      const maxAttempts = 50; // 5초 동안 시도 (50 * 100ms)

      const checker = setInterval(function() {
        attempts++;
        if (!metaFired && typeof fbq === 'function') {
          fbq('track', 'CompleteRegistration');
          console.log('Meta Pixel: CompleteRegistration event fired.');
          metaFired = true;
        }
        if (!gaFired && typeof gtag === 'function') {
          gtag('event', 'sign_up', { 'method': signupMethod });
          console.log('GA4: sign_up event fired.');
          gaFired = true;
        }
        if ((metaFired && gaFired) || attempts >= maxAttempts) {
          clearInterval(checker);
        }
      }, 100);
    }
  } catch (e) {
    console.error('Klairs Signup Tracking Error:', e);
  }
});
</script>


